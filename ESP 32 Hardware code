#include <Adafruit_MPU6050.h>
#include <Adafruit_Sensor.h>
#include <Wire.h>
#include <TinyGPS++.h>

// Pin Definitions
#define GSM_RX 16  // Connect to GSM TX
#define GSM_TX 17  // Connect to GSM RX (Use your 10k/20k resistor divider here!)
#define GPS_RX 18  // Connect to GPS TX
#define GPS_TX 19  // Connect to GPS RX

// Objects
Adafruit_MPU6050 mpu;
TinyGPSPlus gps;
HardwareSerial gsmSerial(1);
HardwareSerial gpsSerial(2);

// Emergency Contact
const char* emergencyNumber = "+91XXXXXXXXXX"; // Change to your number

void setup() {
  Serial.begin(115200);
  gsmSerial.begin(9600, SERIAL_8N1, GSM_RX, GSM_TX);
  gpsSerial.begin(9600, SERIAL_8N1, GPS_RX, GPS_TX);

  // Initialize MPU6050
  if (!mpu.begin()) {
    Serial.println("MPU6050 not found!");
    while (1) yield();
  }
  
  // Set detection thresholds for a "crash"
  mpu.setAccelerometerRange(MPU6050_RANGE_8_G);
  Serial.println("System Ready...");
}

void loop() {
  sensors_event_t a, g, temp;
  mpu.getEvent(&a, &g, &temp);

  // Detect sudden impact (Threshold: > 30 m/s^2) or Sharp Tilt
  if (abs(a.acceleration.x) > 30 || abs(a.acceleration.y) > 30 || abs(a.acceleration.z) < 2) {
    Serial.println("ACCIDENT DETECTED!");
    sendEmergencyAlert();
    delay(10000); // Wait to prevent multiple triggers
  }

  // Update GPS data in background
  while (gpsSerial.available() > 0) {
    gps.encode(gpsSerial.read());
  }
}

void sendEmergencyAlert() {
  String latitude = String(gps.location.lat(), 6);
  String longitude = String(gps.location.lng(), 6);
  String googleMapsLink = "https://www.google.com/maps?q=" + latitude + "," + longitude;

  Serial.println("Sending SMS...");
  
  // Send SMS
  gsmSerial.println("AT+CMGF=1"); // Set SMS to text mode
  delay(1000);
  gsmSerial.print("AT+CMGS=\"");
  gsmSerial.print(emergencyNumber);
  gsmSerial.println("\"");
  delay(1000);
  gsmSerial.print("ACCIDENT ALERT! Location: ");
  gsmSerial.println(googleMapsLink);
  delay(100);
  gsmSerial.write(26); // ASCII code for Ctrl+Z to send
  
  delay(5000);
  
  // Make Voice Call
  Serial.println("Initiating Emergency Call...");
  gsmSerial.print("ATD");
  gsmSerial.print(emergencyNumber);
  gsmSerial.println(";"); 
}
